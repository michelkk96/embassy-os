. /lib/functions/uci-defaults.sh

board_config_update

case "$(board_name)" in
bananapi,bpi-f3)
    ucidef_set_interface_lan 'eth0 wlan0'
    [ -d /sys/class/net/eth1 ] && ucidef_set_interface_wan eth1
    ;;
esac

board_config_flush

exit 0
