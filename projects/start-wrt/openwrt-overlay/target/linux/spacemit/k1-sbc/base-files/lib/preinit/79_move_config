move_config() {
	local partdev

	. /lib/upgrade/common.sh

	# p5 is the FAT "bootfs" partition where platform_copy_config parked the
	# saved config tarball (see lib/upgrade/platform.sh).
	if export_bootdevice && export_partdevice partdev 5; then
		if mount -t vfat -o rw,noatime "/dev/$partdev" /mnt; then
			if [ -f "/mnt/$BACKUP_FILE" ]; then
				mv -f "/mnt/$BACKUP_FILE" /
			fi
			umount /mnt
		fi
	fi
}

boot_hook_add preinit_mount_root move_config

